{
  "name": "kasa-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,scss,md}\"",
    "stylelint": "stylelint \"**/*.scss\"",
    "stylelint:fix": "stylelint \"**/*.scss\" --fix",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "analyze": "vite build --mode analyze",
    "lighthouse": "pnpm build && lhci autorun --collect.startServerCommand=\"pnpm preview\" --collect.startServerReadyPattern=Local",
    "clean": "rm -rf dist .lighthouseci",
    "update:check": "ncu",
    "update:interactive": "ncu -i",
    "update:all": "ncu -u"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "17.7.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.3",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "glob": "^13.0.0",
      "source-map": "^0.7.4",
      "magic-string": "^0.30.0",
      "serialize-javascript": "^7.0.3",
      "tmp": "^0.2.5"
    }
  }
}
